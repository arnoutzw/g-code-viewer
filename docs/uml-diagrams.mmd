%% === STATE DIAGRAM ===
stateDiagram-v2
    [*] --> Empty

    state "Empty" as Empty {
        [*] --> NoData
        NoData : No G-code loaded
        NoData : Canvas shows placeholder
    }

    state "InputMethod" as InputMethod {
        [*] --> PasteMode
        PasteMode --> FileMode : click File tab
        FileMode --> PasteMode : click Paste tab
        PasteMode --> Parsing : click Parse & Render
        FileMode --> FileLoading : drop file or select file
        FileLoading --> Parsing : FileReader.onload
    }

    state "Parsed" as Parsed {
        [*] --> ViewSelection
        state ViewSelection {
            [*] --> View2DActive
            View2DActive --> View3DActive : click 3D tab
            View3DActive --> View2DActive : click 2D tab
        }

        state "Simulation" as SimState {
            [*] --> SimStopped
            SimStopped --> SimPlaying : play()
            SimPlaying --> SimPaused : pause()
            SimPaused --> SimPlaying : play()
            SimPlaying --> SimStopped : stop() or reached end
            SimPaused --> SimStopped : stop()

            SimStopped --> StepMode : step forward/back
            StepMode --> SimStopped : idle
            StepMode --> SimPlaying : play()
        end
    }

    Empty --> InputMethod : user starts input
    InputMethod --> Empty : example selected
    Parsing --> Parsed : parse successful
    Parsed --> InputMethod : modify and re-parse

    state "SpeedControl" as SpeedCtrl {
        [*] --> Speed1x
        Speed1x --> SpeedCustom : adjust slider
        SpeedCustom --> Speed1x : reset
    }

    Parsed --> SpeedCtrl : adjust speed
